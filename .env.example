# Production environment variables for Vite
# Backend API base URL
VITE_API_URL=https://api.skillsprint.site

# AWS Cognito Hosted UI
VITE_COGNITO_DOMAIN=https://<domain-cognito>.auth.ap-southeast-1.amazoncognito.com
VITE_COGNITO_CLIENT_ID=<cognito-client-id>
VITE_COGNITO_REDIRECT_URI=https://www.skillsprint.site/auth/callback
