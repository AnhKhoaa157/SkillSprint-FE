# Example .env (safe to commit). DO NOT store real secrets here.
# Copy this to `.env` and fill real values for local development.

# Application
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Database
POSTGRES_PORT=5432
DB_URL=jdbc:postgresql://localhost:5432/skillsprint
DB_USERNAME=postgres
DB_PASSWORD=your_db_password

# Cognito / Auth
COGNITO_REGION=ap-southeast-1
COGNITO_USER_POOL_ID=your_cognito_user_pool_id
COGNITO_CLIENT_ID=your_cognito_client_id
COGNITO_CLIENT_SECRET=your_cognito_client_secret
COGNITO_DEFAULT_GROUP=LEARNER
COGNITO_ISSUER_URI=https://cognito-idp.ap-southeast-1.amazonaws.com/your_user_pool_id

# AWS credentials (local development only)
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# AWS S3
AWS_S3_BUCKET=your_s3_bucket_name
AWS_S3_PUBLIC_BASE_URL=https://your-s3-bucket.s3.ap-southeast-1.amazonaws.com

# Gemini (or other AI key)
GEMINI_ENABLED=false
GEMINI_API_KEY=your_gemini_api_key

# Notes:
# - Copy this file to `.env` and replace placeholder values with your real credentials.
# - Never commit `.env` containing secrets. Add `.env` to .gitignore if not already ignored.
